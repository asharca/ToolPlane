DATABASE_URL="postgresql://mcp:mcp@localhost:5433/toolplane?schema=public"

# Secret used to sign session JWT cookies. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL used in generated install scripts, callbacks, and connection snippets.
NEXT_PUBLIC_APP_URL="http://localhost:10030"

# Docker Compose publishes the app on this host port. By default it listens on
# all host interfaces so an external proxy can reach it; set APP_HOST_BIND to
# "127.0.0.1" for local-only deployments.
APP_HOST_PORT="10030"
# APP_HOST_BIND="127.0.0.1"
# Optional host publish for the connector WebSocket broker. When TLS terminates
# on a separate proxy host, bind this to a private LAN address such as
# "10.0.10.2:9321" so the proxy can reach the broker directly.
CONNECTOR_WS_HOST_BIND="127.0.0.1:9321"

# Docker Compose app image. The published image is amd64 for server deployments.
TOOLPLANE_IMAGE="ghcr.io/asharca/toolplane:latest"
TOOLPLANE_PLATFORM="linux/amd64"
TOOLPLANE_UPDATE_ENABLED="true"
TOOLPLANE_UPDATE_REPO="asharca/ToolPlane"
TOOLPLANE_UPDATE_ARTIFACT="toolplane-runtime-linux-amd64.tar.gz"

# Optional Docker image build override for bundled hosted agent messaging runners.
HERMES_REPO="https://github.com/NousResearch/hermes-agent.git"
HERMES_REF="7e8f50a14176e02b514631b0b04470acaadae32a"
# HERMES_ARCHIVE_URL="https://github.com/NousResearch/hermes-agent/archive/7e8f50a14176e02b514631b0b04470acaadae32a.tar.gz"

# Local `pnpm dev` only: Compose images already bundle these paths.
# TOOLPLANE_HERMES_ROOT="/absolute/path/to/hermes-agent"
# TOOLPLANE_PYTHON="/absolute/path/to/python"

# WebSocket broker for user-machine connector sandboxes.
# `CONNECTOR_WS_PUBLIC_URL` should be the browser-visible ws/wss endpoint
# (for example `wss://tp.rhzy.ai`), while `CONNECTOR_WS_HOST_BIND` controls the
# private host:port Docker publishes for an external reverse proxy to reach.
CONNECTOR_WS_BIND="0.0.0.0"
CONNECTOR_WS_PORT="9321"
CONNECTOR_WS_PUBLIC_URL="ws://localhost:9321"

# Separate browser origin for the embedded Hermes Dashboard. Local `pnpm dev`
# derives http://<current-host>:9332 automatically. HTTPS deployments must put
# this origin behind TLS and reverse-proxy it to the app's port 9332.
HERMES_DASHBOARD_BIND="0.0.0.0"
HERMES_DASHBOARD_PORT="9332"
# Docker Compose host publish. Use 127.0.0.1 when only a local TLS reverse
# proxy should reach the broker; the signed capability still gates requests.
HERMES_DASHBOARD_HOST_BIND="0.0.0.0"
HERMES_DASHBOARD_HOST_PORT="9332"
# HERMES_DASHBOARD_PUBLIC_URL="https://hermes.example.com"

# Comma-separated emails that are auto-promoted to admin on login/signup.
ADMIN_EMAILS=
