generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  suspended
}

model Server {
  id            String       @id @default(cuid())
  slug          String       @unique
  name          String
  author        String?
  description   String?
  iconUrl       String?
  stars         Int          @default(0)
  isOfficial    Boolean      @default(false)
  isFeatured    Boolean      @default(false)
  curated       Boolean      @default(false)
  installCfg    Json?
  verifiedAt    DateTime?
  verifiedTools Int?
  readme        String?
  categories    Category[]   @relation("ServerCategories")
  deployments   Deployment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String?
  passwordHash     String
  role             UserRole     @default(user)
  status           UserStatus   @default(active)
  locale           String       @default("en")
  detectedTimeZone String?
  timeZoneOverride String?
  apiTokens        ApiToken[]
  ownedWorkspaces  Workspace[]  @relation("WorkspaceOwner")
  memberships      Membership[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  prefix     String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model Client {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  author      String?
  description String?
  iconUrl     String?
  stars       Int        @default(0)
  categories  Category[] @relation("ClientCategories")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Skill {
  id             String           @id @default(cuid())
  slug           String           @unique
  name           String
  author         String?
  description    String?
  iconUrl        String?
  githubSource   String?
  sourceRegistry String?
  sourcePath     String?
  sourceSha      String?
  content        String?
  files          Json?
  score          Int              @default(0)
  curated        Boolean          @default(false)
  categories     Category[]       @relation("SkillCategories")
  installs       InstalledSkill[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Category {
  id      String   @id @default(cuid())
  slug    String   @unique
  name    String
  servers Server[] @relation("ServerCategories")
  clients Client[] @relation("ClientCategories")
  skills  Skill[]  @relation("SkillCategories")
}

model DailySnapshot {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  date       DateTime @db.Date
  rank       Int
  score      Int

  @@unique([entityType, entityId, date])
}

model ScrapeCheckpoint {
  id        String   @id @default(cuid())
  job       String   @unique
  lastSlug  String?
  doneCount Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Workspace {
  id               String                   @id @default(cuid())
  slug             String                   @unique
  name             String
  ownerId          String
  owner            User                     @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members          Membership[]
  deployments      Deployment[]
  installedSkills  InstalledSkill[]
  requestLogs      RequestLog[]
  sandboxes        Sandbox[]
  toolkits         Toolkit[]
  modelProviders   ModelProvider[]
  agents           Agent[]
  agentRuntimes    AgentRuntime[]
  agentAttachments AgentAttachment[]
  agentChannels    AgentChannelConnection[]
  skillInvocations SkillInvocation[]
  syncEvents       SyncEvent[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model Membership {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("member")
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
}

model Deployment {
  id           String          @id @default(cuid())
  workspaceId  String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  serverId     String?
  server       Server?         @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name         String?
  source       String?
  sourceRef    String?
  installCfg   Json?
  status       String          @default("provisioning")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  toolkitLinks ToolkitServer[]
  agentLinks   AgentServer[]
  sandbox      Sandbox?

  @@unique([workspaceId, serverId])
}

model Sandbox {
  id           String         @id @default(cuid())
  workspaceId  String
  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deploymentId String         @unique
  deployment   Deployment     @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  kind         String         @default("docker")
  image        String?
  hostRoot     String?
  network      String         @default("isolated")
  config       Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  agentLinks   AgentSandbox[]
  agentRuntime AgentRuntime?

  @@unique([workspaceId, slug])
}

model InstalledSkill {
  id             String         @id @default(cuid())
  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillId        String?
  skill          Skill?         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  name           String?
  slug           String?
  description    String?
  content        String?
  source         String?
  sourceRef      String?
  status         String         @default("published")
  userInvocable  Boolean        @default(true)
  agentInvocable Boolean        @default(true)
  effort         String         @default("default")
  files          Json?
  createdAt      DateTime       @default(now())
  toolkitLinks   ToolkitSkill[]
  agentLinks     AgentSkill[]

  @@unique([workspaceId, skillId])
}

model RequestLog {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deploymentId String?
  method       String
  path         String
  statusCode   Int
  durationMs   Int
  requestBody  String?
  responseBody String?
  createdAt    DateTime  @default(now())

  @@index([workspaceId, createdAt])
}

model Toolkit {
  id               String               @id @default(cuid())
  workspaceId      String
  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name             String
  slug             String
  visibility       String               @default("private")
  enabled          Boolean              @default(true)
  servers          ToolkitServer[]
  skills           ToolkitSkill[]
  agentLinks       AgentToolkit[]
  installLinks     ToolkitInstallLink[]
  skillInvocations SkillInvocation[]
  syncEvents       SyncEvent[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([workspaceId, slug])
}

// Opaque install link for a toolkit (the `/install/<id>` URL). `id` is the
// unguessable public id → (toolkit, user) mapping; it stores NO token. Each
// install fetch mints/rotates a single named API token
// ("MCPmarket plugin - <toolkit> (<client>)"), so the embedded credential is
// always freshly valid. One link per user per toolkit. The id is a bearer
// secret — anyone with it can mint the owner's install token.
model ToolkitInstallLink {
  id        String   @id
  toolkitId String
  toolkit   Toolkit  @relation(fields: [toolkitId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([toolkitId, userId])
}

model ToolkitServer {
  id           String     @id @default(cuid())
  toolkitId    String
  toolkit      Toolkit    @relation(fields: [toolkitId], references: [id], onDelete: Cascade)
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@unique([toolkitId, deploymentId])
}

model ToolkitSkill {
  id               String         @id @default(cuid())
  toolkitId        String
  toolkit          Toolkit        @relation(fields: [toolkitId], references: [id], onDelete: Cascade)
  installedSkillId String
  installedSkill   InstalledSkill @relation(fields: [installedSkillId], references: [id], onDelete: Cascade)

  @@unique([toolkitId, installedSkillId])
}

model ModelProvider {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name            String
  format          String
  baseUrl         String
  apiKey          String
  models          String[]  @default([])
  modelsFetchedAt DateTime?
  createdAt       DateTime  @default(now())
  agents          Agent[]

  @@unique([workspaceId, name])
}

model Agent {
  id            String                   @id @default(cuid())
  workspaceId   String
  workspace     Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  systemPrompt  String?
  providerId    String?
  provider      ModelProvider?           @relation(fields: [providerId], references: [id], onDelete: SetNull)
  model         String?
  maxSteps      Int                      @default(8)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  servers       AgentServer[]
  skills        AgentSkill[]
  toolkits      AgentToolkit[]
  sandboxes     AgentSandbox[]
  subAgents     AgentSubAgent[]          @relation("AgentParent")
  parentLinks   AgentSubAgent[]          @relation("AgentChild")
  conversations Conversation[]
  channels      AgentChannelConnection[]
  runtime       AgentRuntime?
  attachments   AgentAttachment[]

  @@unique([workspaceId, slug])
}

model AgentRuntime {
  id            String            @id @default(cuid())
  workspaceId   String
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agentId       String            @unique
  agent         Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sandboxId     String            @unique
  sandbox       Sandbox           @relation(fields: [sandboxId], references: [id], onDelete: Cascade)
  kind          String            @default("hermes")
  image         String
  status        String            @default("provisioning")
  configVersion Int               @default(1)
  configHash    String?
  capabilities  Json?
  lastSyncedAt  DateTime?
  lastStartedAt DateTime?
  lastError     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  attachments   AgentAttachment[]

  @@index([workspaceId, kind, status])
}

model AgentAttachment {
  id             String        @id @default(cuid())
  workspaceId    String
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agentId        String
  agent          Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  runtimeId      String?
  runtime        AgentRuntime? @relation(fields: [runtimeId], references: [id], onDelete: SetNull)
  name           String
  mimeType       String
  size           Int
  storage        String        @default("hermes-volume")
  storagePath    String
  createdAt      DateTime      @default(now())

  @@index([workspaceId, agentId, createdAt])
  @@index([conversationId])
}

model AgentChannelConnection {
  id                 String    @id @default(cuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agentId            String
  agent              Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  platform           String
  name               String
  status             String    @default("stopped")
  config             Json?
  credentials        Json?
  inboundTokenHash   String    @unique
  inboundTokenSecret Json
  inboundTokenPrefix String
  runnerPid          Int?
  lastError          String?
  lastStartedAt      DateTime?
  lastEventAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([agentId, platform, name])
  @@index([workspaceId, agentId])
  @@index([platform, status])
}

// A directed link letting one agent delegate to another (same workspace) by
// calling it as a tool. Self-relation: parent → child.
model AgentSubAgent {
  parentId String
  childId  String
  parent   Agent  @relation("AgentParent", fields: [parentId], references: [id], onDelete: Cascade)
  child    Agent  @relation("AgentChild", fields: [childId], references: [id], onDelete: Cascade)

  @@id([parentId, childId])
}

model AgentServer {
  agentId      String
  deploymentId String
  agent        Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@id([agentId, deploymentId])
}

model AgentSkill {
  agentId          String
  installedSkillId String
  agent            Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  installedSkill   InstalledSkill @relation(fields: [installedSkillId], references: [id], onDelete: Cascade)

  @@id([agentId, installedSkillId])
}

model AgentToolkit {
  agentId   String
  toolkitId String
  agent     Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  toolkit   Toolkit @relation(fields: [toolkitId], references: [id], onDelete: Cascade)

  @@id([agentId, toolkitId])
}

model AgentSandbox {
  agentId   String
  sandboxId String
  agent     Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sandbox   Sandbox @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@id([agentId, sandboxId])
}

model Conversation {
  id          String            @id @default(cuid())
  agentId     String
  agent       Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title       String?
  createdAt   DateTime          @default(now())
  messages    Message[]
  attachments AgentAttachment[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  parts          Json
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// Plugin telemetry: a skill firing inside an installed toolkit plugin. Skills
// live on the user's filesystem and never hit the MCP gateway, so this hook
// POST is the only signal of skill usage. source = user|agent, outcome =
// success|error.
model SkillInvocation {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  toolkitId   String?
  toolkit     Toolkit?  @relation(fields: [toolkitId], references: [id], onDelete: SetNull)
  skillSlug   String
  source      String
  outcome     String
  errorClass  String?
  client      String?
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
}

// Plugin telemetry: one SessionStart skill-sync run. outcome = applied (with
// added/removed/updated/total counts) or failure (with a reason class).
model SyncEvent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  toolkitId   String?
  toolkit     Toolkit?  @relation(fields: [toolkitId], references: [id], onDelete: SetNull)
  outcome     String
  added       Int       @default(0)
  removed     Int       @default(0)
  updated     Int       @default(0)
  total       Int       @default(0)
  reason      String?
  client      String?
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
}
