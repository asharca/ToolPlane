DATABASE_URL="postgresql://mcp:mcp@localhost:5433/mcpmarket?schema=public"

# Secret used to sign session JWT cookies. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL used in Hub connection snippets.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated emails that are auto-promoted to admin on login/signup.
ADMIN_EMAILS=
