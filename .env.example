DATABASE_URL="postgresql://mcp:mcp@localhost:5433/toolplane?schema=public"

# Secret used to sign session JWT cookies. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL used in Hub connection snippets.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional Docker build override for bundled hosted agent messaging runners.
HERMES_REPO="https://github.com/NousResearch/hermes-agent.git"
HERMES_REF="7e8f50a14176e02b514631b0b04470acaadae32a"
# HERMES_ARCHIVE_URL="https://github.com/NousResearch/hermes-agent/archive/7e8f50a14176e02b514631b0b04470acaadae32a.tar.gz"

# Local `pnpm dev` only: Compose images already bundle these paths.
# TOOLPLANE_HERMES_ROOT="/absolute/path/to/hermes-agent"
# TOOLPLANE_PYTHON="/absolute/path/to/python"

# WebSocket broker for user-machine connector sandboxes.
# The CLI discovers this from NEXT_PUBLIC_APP_URL and the bootstrap endpoint.
CONNECTOR_WS_BIND="0.0.0.0"
CONNECTOR_WS_PORT="9321"
CONNECTOR_WS_PUBLIC_URL="ws://localhost:9321"

# Comma-separated emails that are auto-promoted to admin on login/signup.
ADMIN_EMAILS=
